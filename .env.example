# Shared defaults
OPENAI_API_KEY=
OPENAI_API_BASE_URL=

# Embeddings
EMBEDDING_PROVIDER=fastembed
EMBEDDING_API_KEY=
EMBEDDING_API_BASE_URL=
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
EMBEDDING_DIMENSIONS=384
RERANKER_ENABLED=true
RERANKER_PROVIDER=fastembed_late_interaction
RERANKER_MODEL=answerdotai/answerai-colbert-small-v1
RERANKER_CANDIDATES=24

# Chat
CHAT_PROVIDER=disabled
CHAT_API_KEY=
CHAT_API_BASE_URL=
CHAT_MODEL=gpt-4o-mini

# Retrieval / indexing
QDRANT_URL=http://qdrant:6333
QDRANT_INDEX=tech_docs
TOP_K=8
CHUNK_SIZE=1400
CHUNK_OVERLAP=200
PDF_EXTRACTOR=hybrid
FASTEMBED_CACHE_PATH=/app/data/cache/fastembed
HOST_SOURCE_DOCS_DIR=/home/as/Документы/RAG_DOCS
SOURCE_DOCS_DIR=/documents/rag_docs
INPUT_DIR=/documents/rag_docs
INSTALL_DOCLING=false
