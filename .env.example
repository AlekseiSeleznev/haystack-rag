# Shared defaults
OPENAI_API_KEY=
OPENAI_API_BASE_URL=

# Embeddings
EMBEDDING_API_KEY=
EMBEDDING_API_BASE_URL=
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# Chat
CHAT_API_KEY=
CHAT_API_BASE_URL=
CHAT_MODEL=gpt-4o-mini

# Retrieval / indexing
QDRANT_URL=http://qdrant:6333
QDRANT_INDEX=tech_docs
TOP_K=8
CHUNK_SIZE=1400
CHUNK_OVERLAP=200

